NODE_ENV=development
PORT=4000

# MongoDB
MONGO_URI=mongodb://localhost:27017/lms

# JWT
JWT_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Email / Resend
RESEND_API_KEY=
EMAIL_FROM=no-reply@example.com
APP_NAME=LMS

# Encryption (see scripts/keygen.encryption.js)
DB_ENCRYPTION_KEYS={"key1":"base64-encoded-32-byte-key"}
DB_ENCRYPTION_ACTIVE_KEY_ID=key1

# URLs
API_BASE_URL=http://localhost:4000
APP_BASE_URL=http://localhost:3000

# Debugging
DEBUG=
